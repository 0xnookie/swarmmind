{
  "name": "swarmmind",
  "productName": "SwarmMind",
  "version": "0.14.1",
  "description": "Multi-agent AI coding workspace with shared MCP memory",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "node --experimental-strip-types tests/lib-units.mts",
    "build": "electron-vite build",
    "smoke": "node tests/smoke.mjs",
    "preview": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "rebuild": "electron-builder install-app-deps",
    "icons": "node scripts/make-icons.cjs",
    "postinstall": "node scripts/copy-ort-wasm.js"
  },
  "keywords": [
    "electron",
    "mcp",
    "ai",
    "coding",
    "agents"
  ],
  "author": "SwarmMind",
  "license": "MIT",
  "comment:dependencies": "Only packages required at RUNTIME by the main/preload process (electron-vite externalizes `dependencies`) or as native addons belong here. electron-builder copies the full `dependencies` tree into the asar, so anything that is only bundled into out/renderer by Vite MUST live in devDependencies — otherwise it is shipped twice and bloats the installer.",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.10.0",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "groq-sdk": "^1.2.1",
    "node-pty": "^1.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "^4.3.4",
    "@xenova/transformers": "^2.17.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "allotment": "^1.20.3",
    "electron": "^32.2.7",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "playwright-core": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "to-ico": "^1.1.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "zustand": "^4.5.4"
  }
}
