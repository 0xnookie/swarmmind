{
  "include": [
    "electron.vite.config.*",
    "electron-builder.config.*",
    "electron/**/*",
    "memory/**/*",
    "mcp/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "out/main",
    "types": ["node"],
    "paths": {
      "@memory/*": ["./memory/*"],
      "@mcp/*": ["./mcp/*"]
    }
  }
}
